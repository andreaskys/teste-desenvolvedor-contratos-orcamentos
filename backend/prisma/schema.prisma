generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Company {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  cnpj              String             @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  auditLogs         AuditLog[]
  contractTemplates ContractTemplate[]
  contracts         Contract[]
  notifications     Notification[]
  obras             Obra[]
  signatureRequests SignatureRequest[]
  uploads           Upload[]
  users             User[]

  @@map("companies")
}

model Notification {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("INFO")
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])

  @@map("notifications")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(OPERATOR)
  companyId String   @map("company_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])

  @@map("users")
}

model ContractTemplate {
  id        String                  @id @default(uuid())
  name      String
  content   String
  companyId String                  @map("company_id")
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  embedding Unsupported("vector")?
  fields    ContractTemplateField[]
  company   Company                 @relation(fields: [companyId], references: [id])
  contracts Contract[]

  @@index([companyId])
  @@map("contract_templates")
}

model ContractTemplateField {
  id         String           @id @default(uuid())
  templateId String           @map("template_id")
  label      String
  key        String
  type       String           @default("text")
  required   Boolean          @default(true)
  template   ContractTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("contract_template_fields")
}

model Contract {
  id               String            @id @default(uuid())
  number           String            @unique
  title            String
  value            Decimal           @db.Decimal(15, 2)
  startDate        DateTime          @map("start_date")
  endDate          DateTime          @map("end_date")
  status           ContractStatus    @default(DRAFT)
  companyId        String            @map("company_id")
  templateId       String?           @map("template_id")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  contractType     String            @default("Outros") @map("contract_type")
  filledFields     Json?             @default("{}") @map("filled_fields")
  relatedParty     String            @default("Não Informado") @map("related_party")
  company          Company           @relation(fields: [companyId], references: [id])
  template         ContractTemplate? @relation(fields: [templateId], references: [id])
  obras            Obra[]
  signatureRequest SignatureRequest?

  @@index([companyId])
  @@index([status])
  @@index([endDate])
  @@map("contracts")
}

model SignatureRequest {
  id         String          @id @default(uuid())
  contractId String          @unique @map("contract_id")
  status     SignatureStatus @default(AWAITING)
  email      String
  phone      String?
  link       String
  logs       Json?           @default("[]")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  channel    String          @default("EMAIL")
  companyId  String          @map("company_id")
  company    Company         @relation(fields: [companyId], references: [id])
  contract   Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("signature_requests")
}

model Obra {
  id             String           @id @default(uuid())
  name           String
  description    String?
  budget         Decimal          @db.Decimal(15, 2)
  startDate      DateTime         @map("start_date")
  endDate        DateTime         @map("end_date")
  companyId      String           @map("company_id")
  contractId     String           @map("contract_id")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  costs          ObraCusto[]
  manutencoes    ObraManutencao[]
  steps          ObraStep[]
  vistorias      ObraVistoria[]
  company        Company          @relation(fields: [companyId], references: [id])
  contract       Contract         @relation(fields: [contractId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([companyId])
  @@index([contractId])
  @@map("obras")
}

model ObraStep {
  id          String   @id @default(uuid())
  obraId      String   @map("obra_id")
  title       String
  description String?
  order       Int
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  obra        Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@map("obra_steps")
}

model ObraVistoria {
  id          String   @id @default(uuid())
  obraId      String   @map("obra_id")
  type        String
  description String
  photos      Json     @default("[]")
  createdAt   DateTime @default(now())
  obra        Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@map("obra_vistorias")
}

model ObraCusto {
  id          String   @id @default(uuid())
  obraId      String   @map("obra_id")
  category    String
  description String
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  obra        Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@map("obra_custos")
}

model ObraManutencao {
  id          String   @id @default(uuid())
  obraId      String   @map("obra_id")
  description String
  date        DateTime @default(now())
  provider    String?
  cost        Decimal? @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  obra        Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@map("obra_manutencoes")
}

model PurchaseOrder {
  id         String   @id @default(uuid())
  obraId     String   @map("obra_id")
  number     String   @unique
  vendor     String
  amount     Decimal  @db.Decimal(15, 2)
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  payingCnpj String?  @map("paying_cnpj")
  obra       Obra     @relation(fields: [obraId], references: [id])

  @@map("purchase_orders")
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  action    String
  resource  String
  payload   Json?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([resource])
  @@map("audit_logs")
}

model Upload {
  id         String   @id @default(uuid())
  filename   String
  path       String
  mimetype   String
  size       Int
  createdAt  DateTime @default(now())
  companyId  String   @map("company_id")
  entityId   String?  @map("entity_id")
  entityType String?  @map("entity_type")
  company    Company  @relation(fields: [companyId], references: [id])

  @@map("uploads")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  EXPIRED
  CANCELLED
  SIGNED
}

enum SignatureStatus {
  AWAITING
  SIGNED
  EXPIRED
  REJECTED
}
